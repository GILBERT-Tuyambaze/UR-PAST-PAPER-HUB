# Core backend
DATABASE_URL=postgresql://username:password@host:5432/database_name
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
FRONTEND_URL=https://paperhubur.vercel.app
PYTHON_BACKEND_URL=https://api.example.com
FRONTEND_API_BASE_URL=https://api.example.com
CORS_ALLOWED_ORIGINS=https://paperhubur.vercel.app
DEBUG=false

# Frontend build/runtime
VITE_API_BASE_URL=https://api.example.com

# Admin bootstrap
ADMIN_USER_EMAIL=admin@example.com
ADMIN_USER_ID=replace_with_admin_user_id
ALLOW_RUNTIME_ENV_MUTATION=false

# Auth providers
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=replace_with_client_id
OIDC_CLIENT_SECRET=replace_with_client_secret
OIDC_SCOPE=openid email profile

# Password reset
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=replace_with_mail_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=UR Academic Resource Hub
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EXPOSE_PASSWORD_RESET_LINKS=false

# Firebase
FIREBASE_PROJECT_ID=project-id
VITE_FIREBASE_API_KEY=replace_with_public_api_key
VITE_FIREBASE_AUTH_DOMAIN=project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=project-id
VITE_FIREBASE_APP_ID=replace_with_app_id
VITE_FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
VITE_FIREBASE_STORAGE_BUCKET=project-id.firebasestorage.app
